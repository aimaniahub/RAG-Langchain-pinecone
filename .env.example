# Application
APP_NAME=company-rag
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000
DISABLE_DOCS=false
UI_ENABLED=true
AUTO_MIGRATE=true
PHASE=4

# Database (local SQLite default; Railway Postgres plugin)
DATABASE_URL=sqlite:///./data/company_rag.db
# Railway: DATABASE_URL=${{Postgres.DATABASE_URL}}
# (postgres:// is auto-normalized to postgresql://)

# S3 / Railway object storage (empty = local ./data/uploads)
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
S3_REGION=auto
LOCAL_STORAGE_DIR=./data/uploads

# Auth (set AUTH_ENABLED=true for production)
AUTH_ENABLED=false
API_KEY_ADMIN=dev-admin-key
API_KEY_USER=dev-user-key
BOOTSTRAP_ADMIN_KEY=
# API_KEYS_JSON=[{"key":"my-admin","role":"admin","name":"ops"}]

# Rate limits
RATE_LIMIT_ENABLED=true
RATE_LIMIT_QUERY_PER_MINUTE=30
RATE_LIMIT_INGEST_PER_MINUTE=10
MAX_UPLOAD_BYTES=10485760
MAX_QUESTION_CHARS=2000

# CORS (* for local UI; set real origins in production)
CORS_ORIGINS=*

# OpenRouter (LLM)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME=company-rag
LLM_TEMPERATURE=0.0
OPENROUTER_TIMEOUT_SECONDS=60
OPENROUTER_MAX_RETRIES=2

# Free local HuggingFace embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSION=384

# Pinecone (index dimension must be 384)
PINECONE_API_KEY=
PINECONE_INDEX_NAME=company-rag
PINECONE_NAMESPACE=default
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=5
MAX_CHUNKS_PER_INGEST=50
MAX_CONTEXT_CHARS=4000

# S0/S1 speed
WARMUP_EMBEDDINGS=true
INCLUDE_TIMINGS=true
EMBED_CACHE_ENABLED=true
ANSWER_CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=2048
RETRIEVE_TOP_K=10
RETURN_TOP_N=3
MIN_RETRIEVAL_SCORE=0.15
MAX_CHARS_PER_CHUNK=800
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
STREAMING_ENABLED=true

# Logging
LOG_FORMAT=text
LOG_LEVEL=INFO
